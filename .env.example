# Copy this file to `.env` and fill in real values.
# `.env` should be gitignored; `.env.example` is checked in as a template.

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Default model used by the chatbot agent loop.
# Any model identifier listed at https://openrouter.ai/models works here.
# `openrouter/free` auto-routes to whichever free model is currently available
# (the cheapest/fastest free provider). Best for development.
MODEL=openrouter/free
# Recommended paid alternative once you're evaluating planning quality:
# MODEL=anthropic/claude-sonnet-4-5

# Optional fallback chain: when MODEL errors, OpenRouter tries these next in
# order. Comma-separated, no spaces. Usually unnecessary when MODEL is already
# `openrouter/free`, but useful when pinning to a specific paid model.
# Example: MODEL_FALLBACKS=anthropic/claude-haiku-4-5,openai/gpt-4o-mini
MODEL_FALLBACKS=
