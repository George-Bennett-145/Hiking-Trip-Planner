# Files NOT to upload to Cloud Build. Critical: this file overrides .gitignore
# during `gcloud run deploy --source`, so we must NOT exclude output/*.graphml
# (which .gitignore does exclude) — those routing graphs are needed in the image.

.gcloudignore
.git/
.gitignore

